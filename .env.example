# PostgreSQL connection string.
# - On Vercel, this is injected automatically when you connect a Postgres store
#   (Neon / Vercel Postgres) to the project.
# - For local development, point it at any Postgres instance, e.g. a free Neon
#   database or a local Docker container:
#     DATABASE_URL="postgresql://user:password@localhost:5432/hakeng?schema=public"
DATABASE_URL="postgresql://user:password@host:5432/hakeng?schema=public"

# Vercel Blob — token for PDF uploads.
# Injected automatically on Vercel when a Blob store is linked to the project.
# For local dev, run `vercel env pull` (creates .env.local) or paste the token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
